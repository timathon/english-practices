{
  "level": "Senior High 1 Semester 1",
  "part": "Welcome Unit",
  "sections": [
    {
      "section": "Model Essay Basic",
      "tree": {
        "id": "root",
        "text": "My Student Profile (Basic)",
        "translation": "我的学生个人档案（基础版）",
        "children": [
          {
            "id": "b_p1",
            "text": "Greeting & Personal Info",
            "translation": "自我介绍与基本信息",
            "children": [
              {
                "id": "b_s1",
                "text": "My name is Li Hua.",
                "translation": "我的名字叫李华。"
              },
              {
                "id": "b_s2",
                "text": "I am 15 years old and I am a Grade 10 student.",
                "translation": "我今年15岁，是一名高一学生。"
              }
            ]
          },
          {
            "id": "b_p2",
            "text": "Personality & Hobbies",
            "translation": "性格与爱好",
            "children": [
              {
                "id": "b_s3",
                "text": "I am outgoing and friendly.",
                "translation": "我性格外向且友好。"
              },
              {
                "id": "b_s4",
                "text": "I like reading books and playing basketball.",
                "translation": "我喜欢读书和打篮球。"
              }
            ]
          },
          {
            "id": "b_p3",
            "text": "Future Plans",
            "translation": "未来计划",
            "children": [
              {
                "id": "b_s5",
                "text": "I plan to become a doctor in the future.",
                "translation": "我计划未来成为一名医生。"
              }
            ]
          }
        ]
      }
    },
    {
      "section": "Model Essay Advanced",
      "tree": {
        "id": "root_adv",
        "text": "My Student Profile (Advanced)",
        "translation": "我的学生个人档案（高级版）",
        "children": [
          {
            "id": "a_p1",
            "text": "Introduction & Academic Life",
            "translation": "导入与学校生活",
            "children": [
              {
                "id": "a_s1",
                "text": "My name is Li Hua, a passionate Grade 10 student studying at a senior high school.",
                "translation": "我叫李华，是一名在一所高中就读、充满热情的高一学生。"
              },
              {
                "id": "a_s2",
                "text": "Although high school life is challenging, I look forward to exploring new subjects.",
                "translation": "虽然高中生活很有挑战性，但我很期待探索新的科目。"
              }
            ]
          },
          {
            "id": "a_p2",
            "text": "Personality & Interests",
            "translation": "个性与兴趣爱好",
            "children": [
              {
                "id": "a_s3",
                "text": "Being an outgoing and curious person, I learn best by doing experiments in the lab.",
                "translation": "作为一个性格外向、求知欲强的人，我通过在实验室做实验能学得最好。"
              },
              {
                "id": "a_s4",
                "text": "In addition, playing football at the weekends helps me keep fit.",
                "translation": "此外，周末踢足球帮助我保持身体健康。"
              }
            ]
          },
          {
            "id": "a_p3",
            "text": "Aspirations",
            "translation": "抱负与抱负实现",
            "children": [
              {
                "id": "a_s5",
                "text": "Ultimately, I hope to start my own IT company to change the world.",
                "translation": "最终，我希望能创办我自己的IT公司来改变世界。"
              }
            ]
          }
        ]
      }
    }
  ]
}