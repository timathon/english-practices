  "tree": {
    "id": "root",
    "text": "The Fisherman and the Golden Fish",
    "emoji": "🐟",
    "state": "emoji",
    "children": [
      {
        "id": "p1",
        "text": "There was once a fisherman who lived in a small house by the sea with his wife.",
        "emoji": "🎣",
        "highlight": "There was once, who",
        "keywords": "fisherman lived, small house, by the sea",
        "children": [
          {
            "id": "p1_1",
            "text": "One day, something very special happened. He caught a little golden fish.",
            "emoji": "✨",
            "highlight": "One day",
            "keywords": "special happened, caught golden fish",
            "children": []
          },
          {
            "id": "p1_2",
            "text": "It promised me whatever I wanted if I set it free.",
            "emoji": "🤝",
            "highlight": "if",
            "keywords": "promised whatever, set it free",
            "children": [
              {
                "id": "p1_3",
                "text": "I felt sorry for the fish, so I just put it back into the sea.",
                "emoji": "🥺",
                "highlight": "so",
                "keywords": "felt sorry, put it back",
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "p2",
        "text": "His wife was very angry and made him find the fish.",
        "emoji": "😡",
        "highlight": "and",
        "keywords": "wife very angry, made him find",
        "children": [
          {
            "id": "p2_1",
            "text": "'My wife was very angry because I didn't make a wish. We need a new pot.'",
            "emoji": "🍲",
            "highlight": "because",
            "keywords": "didn't make wish, need new pot",
            "children": [
              {
                "id": "p2_2",
                "text": "The golden fish said yes, and it went back into the water.",
                "emoji": "✅",
                "highlight": "and",
                "keywords": "said yes, went back",
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "p3",
        "text": "Back home, the fisherman found a new pot outside the house.",
        "emoji": "🏠",
        "keywords": "found new pot",
        "children": [
          {
            "id": "p3_1",
            "text": "'You fool! Can't you see we need a new house instead? Go back again and ask for one!'",
            "emoji": "💢",
            "highlight": "instead, and",
            "keywords": "You fool, need new house",
            "children": [
              {
                "id": "p3_2",
                "text": "Again, the golden fish granted his wish.",
                "emoji": "✨",
                "highlight": "Again",
                "keywords": "granted his wish",
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "p4",
        "text": "The fisherman went back home. But his house was now big and beautiful.",
        "emoji": "🏰",
        "highlight": "But",
        "keywords": "house was big and beautiful",
        "children": [
          {
            "id": "p4_1",
            "text": "'The house is nice, but I want to be rich too! Go back and ask for money!'",
            "emoji": "💰",
            "highlight": "but, too",
            "keywords": "want to be rich",
            "children": []
          }
        ]
      }
    ]
  }
