  "section": "Model Essay 1",
  "tree": {
    "id": "root",
    "text": "This is a story about a lion and a mouse.",
    "emoji": "📖",
    "state": "emoji",
    "children": [
      {
        "id": "p1",
        "text": "One day, a lion was sleeping.",
        "emoji": "💤",
        "highlight": "One day",
        "keywords": "lion, sleeping",
        "children": [
          {
            "id": "p1_1",
            "text": "A mouse walked by and woke him up.",
            "emoji": "🐭",
            "highlight": "and",
            "keywords": "mouse walked by, woke him up",
            "children": [],
            "cn": "一只老鼠走过来，把他吵醒了。"
          }
        ],
        "cn": "有一天，一只狮子正在睡觉。"
      },
      {
        "id": "p2",
        "text": "The lion caught the mouse, but the mouse said, 'Please let me go.'",
        "emoji": "😨",
        "highlight": "but",
        "keywords": "caught the mouse, let me go",
        "children": [
          {
            "id": "p2_1",
            "text": "'One day I can help you.'",
            "emoji": "🤝",
            "keywords": "can help you",
            "children": [
              {
                "id": "p2_2",
                "text": "The lion laughed and let it go.",
                "emoji": "😂",
                "highlight": "and",
                "keywords": "laughed, let it go",
                "children": [],
                "cn": "狮子笑了笑，放走了它。"
              }
            ],
            "cn": "“总有一天我可以帮助你。”"
          }
        ],
        "cn": "狮子抓住了老鼠，但是老鼠说：'请放了我吧。'"
      },
      {
        "id": "p3",
        "text": "Later, a hunter caught the lion in a net.",
        "emoji": "猎",
        "highlight": "Later",
        "keywords": "hunter caught, in a net",
        "children": [
          {
            "id": "p3_1",
            "text": "The mouse saw this and helped him.",
            "emoji": "👀",
            "highlight": "and",
            "keywords": "saw this, helped him",
            "children": [
              {
                "id": "p3_2",
                "text": "It bit through the net, so the lion got out.",
                "emoji": "🦷",
                "highlight": "so",
                "keywords": "bit through, got out",
                "children": [
                  {
                    "id": "p3_3",
                    "text": "The lion thanked the mouse.",
                    "emoji": "🙏",
                    "keywords": "thanked the mouse",
                    "children": [],
                    "cn": "狮子感谢了老鼠。"
                  }
                ],
                "cn": "它咬破了网，所以狮子逃出来了。"
              }
            ],
            "cn": "老鼠看到了这一幕并帮助了他。"
          }
        ],
        "cn": "后来，一个猎人用网抓住了狮子。"
      }
    ]
  }
}