  "sections": [
    {
      "section": "Model Essay 1",
      "tree": {
        "id": "root",
        "text": "This is a story about a lion and a mouse.",
        "emoji": "📖",
        "state": "emoji",
        "children": [
          {
            "id": "p1",
            "text": "One day, a lion was sleeping.",
            "emoji": "💤",
            "highlight": "One day",
            "keywords": "lion, sleeping",
            "children": [
              {
                "id": "p1_1",
                "text": "A mouse walked by and woke him up.",
                "emoji": "🐭",
                "highlight": "and",
                "keywords": "mouse walked by, woke him up",
                "children": [],
                "cn": "一只老鼠走过来，把他吵醒了。"
              }
            ],
            "cn": "有一天，一只狮子正在睡觉。"
          },
          {
            "id": "p2",
            "text": "The lion caught the mouse, but the mouse said, 'Please let me go.'",
            "emoji": "😨",
            "highlight": "but",
            "keywords": "caught the mouse, let me go",
            "children": [
              {
                "id": "p2_1",
                "text": "'One day I can help you.'",
                "emoji": "🤝",
                "keywords": "can help you",
                "children": [
                  {
                    "id": "p2_2",
                    "text": "The lion laughed and let it go.",
                    "emoji": "😂",
                    "highlight": "and",
                    "keywords": "laughed, let it go",
                    "children": [],
                    "cn": "狮子笑了笑，放走了它。"
                  }
                ],
                "cn": "“总有一天我可以帮助你。”"
              }
            ],
            "cn": "狮子抓住了老鼠，但是老鼠说：'请放了我吧。'"
          },
          {
            "id": "p3",
            "text": "Later, a hunter caught the lion in a net.",
            "emoji": "猎",
            "highlight": "Later",
            "keywords": "hunter caught, in a net",
            "children": [
              {
                "id": "p3_1",
                "text": "The mouse saw this and helped him.",
                "emoji": "👀",
                "highlight": "and",
                "keywords": "saw this, helped him",
                "children": [
                  {
                    "id": "p3_2",
                    "text": "It bit through the net, so the lion got out.",
                    "emoji": "🦷",
                    "highlight": "so",
                    "keywords": "bit through, got out",
                    "children": [
                      {
                        "id": "p3_3",
                        "text": "The lion thanked the mouse.",
                        "emoji": "🙏",
                        "keywords": "thanked the mouse",
                        "children": [],
                        "cn": "狮子感谢了老鼠。"
                      }
                    ],
                    "cn": "它咬破了网，所以狮子逃出来了。"
                  }
                ],
                "cn": "老鼠看到了这一幕并帮助了他。"
              }
            ],
            "cn": "后来，一个猎人用网抓住了狮子。"
          }
        ]
      }
    },
    {
      "section": "Model Essay 2",
      "tree": {
        "id": "root_2",
        "text": "This is a story about a lion and a mouse.",
        "emoji": "📖",
        "state": "emoji",
        "children": [
          {
            "id": "p1_2",
            "text": "Once upon a time, a big lion was sleeping peacefully.",
            "emoji": "💤",
            "highlight": "Once upon a time",
            "keywords": "big lion, sleeping peacefully",
            "children": [
              {
                "id": "p1_1_2",
                "text": "Suddenly, a little mouse walked by and woke him up.",
                "emoji": "🐭",
                "highlight": "Suddenly, and",
                "keywords": "little mouse, walked by, woke him up",
                "children": [],
                "cn": "突然，一只小老鼠走过来把他吵醒了。"
              }
            ],
            "cn": "很久很久以前，一只大狮子正在安静地睡觉。"
          },
          {
            "id": "p2_2",
            "text": "The lion caught the mouse, but the little mouse said, 'Please let me go.'",
            "emoji": "😨",
            "highlight": "but",
            "keywords": "caught the mouse, said, let me go",
            "children": [
              {
                "id": "p2_1_2",
                "text": "'I promise I can help you one day.'",
                "emoji": "🤝",
                "keywords": "promise, can help you",
                "children": [
                  {
                    "id": "p2_2_2",
                    "text": "The lion laughed at the idea, but let it go.",
                    "emoji": "😂",
                    "highlight": "but",
                    "keywords": "laughed at, let it go",
                    "children": [],
                    "cn": "狮子嘲笑了这个主意，但还是算了。"
                  }
                ],
                "cn": "“我保证有一天我可以帮助你。”"
              }
            ],
            "cn": "狮子抓住了老鼠，但是小老鼠说：'请放了我吧。'"
          },
          {
            "id": "p3_2",
            "text": "Some days later, a hunter caught the lion in a large net.",
            "emoji": "猎",
            "highlight": "Some days later",
            "keywords": "hunter caught, large net",
            "children": [
              {
                "id": "p3_1_2",
                "text": "Thankfully, the mouse saw this and came to help him.",
                "emoji": "🦸",
                "highlight": "Thankfully, and",
                "keywords": "mouse saw this, came to help",
                "children": [
                  {
                    "id": "p3_2_2",
                    "text": "It bit through the net quickly, so the lion got out safely.",
                    "emoji": "🦷",
                    "highlight": "so",
                    "keywords": "bit through quickly, got out safely",
                    "children": [
                      {
                        "id": "p3_3_2",
                        "text": "They became good friends.",
                        "emoji": "❤️",
                        "keywords": "became good friends",
                        "children": [],
                        "cn": "他们成了好朋友。"
                      }
                    ],
                    "cn": "它很快咬断了网，所以狮子安全脱身了。"
                  }
                ],
                "cn": "谢天谢地，老鼠看到了这一幕，过来帮助他。"
              }
            ],
            "cn": "几天后，一个猎人抓住了被困在巨网里的狮子。"
          }
        ]
      }
    }
  ]
}