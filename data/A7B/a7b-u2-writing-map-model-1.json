    "emoji": "🏫",
    "children": [
      {
        "id": "p1",
        "text": "I am a student at Kunming Middle School. We have many rules here.",
        "emoji": "👨‍🎓",
        "keywords": "student, Kunming Middle School, many rules",
        "children": [
          {
            "id": "p1_1",
            "text": "First, we must arrive at school on time. We can't be late for class.",
