<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animal Friends - Sentence Architect</title>
    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --secondary: #1cb0f6;
            --secondary-dark: #1185ba;
            --warning: #ffc800;
            --warning-dark: #e5b400;
            --danger: #ff4b4b;
            --danger-dark: #d33131;
            --neutral: #e5e5e5;
            --text: #4b4b4b;
            --white: #ffffff;
            --bg: #f0f2f5;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0; padding: 0;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; user-select: none;
        }

        #app {
            width: 100%; max-width: 600px;
            background: var(--white); min-height: 100vh;
            position: relative; box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            display: flex; flex-direction: column;
        }

        @media (min-width: 600px) {
            #app { min-height: 90vh; border-radius: 20px; overflow: hidden; }
        }

        .screen { display: none; flex-direction: column; height: 100%; padding: 20px; flex-grow: 1; }
        .screen.active { display: flex; }

        header { text-align: center; margin-bottom: 20px; }
        h1 { color: var(--primary); margin: 0; font-size: 2rem; }
        @media (max-width: 480px) { h1 { font-size: 1.4rem; } }
        h2 { font-size: 1.1rem; color: #999; margin-top: 5px; font-weight: normal; }

        .challenge-grid { display: grid; gap: 15px; overflow-y: auto; padding-bottom: 80px; }
        .challenge-card {
            background: var(--white); border: 2px solid var(--neutral); border-bottom: 4px solid var(--neutral);
            border-radius: 16px; padding: 15px; cursor: pointer; transition: transform 0.1s, border-color 0.1s;
        }
        .challenge-card:active { transform: translateY(2px); border-bottom-width: 2px; }
        .challenge-card:hover { background-color: #fafafa; border-color: #ccc; }
        .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
        .card-title { font-size: 1.1rem; font-weight: bold; margin: 0; }
        .card-stats { 
            font-size: 0.8rem; color: #777; display: flex; justify-content: space-between; align-items: center;
            margin-top: 10px; background: #f8f9fa; padding: 10px 12px; border-radius: 12px; border: 1px solid #eee;
        }
        .stat-row { display: flex; flex-direction: column; align-items: flex-start; }
        .stat-row:last-child { align-items: flex-end; }
        .stat-label { font-weight: bold; color: #aaa; font-size: 0.7rem; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 2px; }
        .stat-val { color: var(--text); font-weight: 600; font-size: 0.9rem; }

        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .close-btn { font-size: 1.5rem; cursor: pointer; color: #ccc; background: none; border: none; }
        .progress-container {
            flex-grow: 1; margin: 0 15px; height: 16px; background-color: var(--neutral);
            border-radius: 8px; display: flex; overflow: hidden;
        }
        .progress-segment { flex-grow: 1; border-right: 1px solid var(--white); }
        .progress-segment.green { background-color: var(--primary); }
        .progress-segment.yellow { background-color: var(--warning); }
        .progress-segment.red { background-color: var(--danger); }

        .question-area { flex-grow: 1; display: flex; flex-direction: column; justify-content: center; position: relative; }
        .prompt-container { text-align: center; margin-bottom: 20px; }
        .prompt-cn { font-size: 1.3rem; color: #333; font-weight: bold; margin-bottom: 5px; }
        .prompt-hint-btn { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--warning); filter: drop-shadow(0 2px 2px rgba(0,0,0,0.1)); transition: transform 0.2s; }
        .prompt-hint-btn:hover { transform: scale(1.1); }
        .hint-text { font-size: 0.9rem; color: #666; font-style: italic; margin-top: 5px; min-height: 1.2em; visibility: hidden; }
        .hint-text.visible { visibility: visible; animation: fadeIn 0.3s; }

        .answer-area {
            min-height: 70px; border-top: 2px solid var(--neutral); border-bottom: 2px solid var(--neutral);
            background: #fafafa; margin-bottom: 30px; display: flex; flex-wrap: wrap; gap: 8px; padding: 15px;
            align-items: center; justify-content: center; border-radius: 8px;
        }
        .word-pool { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 20px; }
        .word-btn {
            background: var(--white); border: 2px solid var(--neutral); border-bottom: 4px solid var(--neutral);
            border-radius: 12px; padding: 10px 14px; font-size: 1.1rem; cursor: pointer; color: var(--text);
            position: relative; transition: all 0.1s; display: flex; flex-direction: column; align-items: center;
        }
        .word-btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .word-btn.selected { background: var(--neutral); color: transparent; border-color: transparent; pointer-events: none; }
        .word-btn.selected .ipa { display: none; }
        .word-btn-answer {
            background: var(--white); border: 2px solid var(--secondary); border-bottom: 4px solid var(--secondary-dark);
            border-radius: 12px; padding: 10px 14px; font-size: 1.1rem; cursor: pointer; color: var(--secondary-dark);
        }
        .ipa { font-size: 0.75rem; color: #999; font-weight: normal; margin-top: 2px; }
        .footer-action { padding-top: 20px; border-top: 2px solid var(--neutral); }
        .check-btn {
            width: 100%; padding: 15px; border-radius: 16px; font-size: 1.2rem; font-weight: bold;
            color: white; background-color: var(--primary); border: none; border-bottom: 5px solid var(--primary-dark);
            cursor: pointer; text-transform: uppercase;
        }
        .check-btn:active { transform: translateY(2px); border-bottom-width: 3px; }
        .check-btn:disabled { background-color: var(--neutral); border-bottom-color: #ccc; color: #999; cursor: not-allowed; transform: none; }
        .check-btn.wrong { background-color: var(--danger); border-bottom-color: var(--danger-dark); animation: shake 0.5s; }
        .check-btn.correct { background-color: var(--primary); animation: bounce 0.5s; }

        .feedback-area {
            height: 110px; margin-bottom: 10px; padding: 10px; border-radius: 12px; text-align: center;
            visibility: hidden; display: flex; flex-direction: column; justify-content: center;
        }
        .feedback-area.visible { visibility: visible; }
        .feedback-area.correct { background-color: #d7ffb8; }
        .feedback-area.wrong { background-color: #ffdfe0; }

        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);
            display: none; align-items: center; justify-content: center; z-index: 2000;
        }
        .modal-content {
            background: white; width: 90%; max-width: 500px; max-height: 80vh; border-radius: 20px;
            padding: 20px; display: flex; flex-direction: column; box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        .log-list { flex-grow: 1; overflow-y: auto; margin-bottom: 15px; }
        .mistake-item { padding: 12px; border-bottom: 1px solid #eee; }
        .mistake-item:last-child { border-bottom: none; }
        .fail-count { background: var(--danger); color: white; border-radius: 10px; padding: 2px 6px; font-size: 0.7rem; float: right;}
        .footer-links { text-align: center; margin-top: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; }
        .text-link { background: none; border: none; cursor: pointer; font-size: 0.9rem; text-decoration: underline; }
        .text-link.danger { color: var(--danger); }
        .text-link.muted { color: #999; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
        @keyframes bounce { 0%, 20%, 50%, 80%, 100% {transform: translateY(0);} 40% {transform: translateY(-10px);} 60% {transform: translateY(-5px);} }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div id="app">
    <div id="home-screen" class="screen active">
        <header>
            <div style="display: flex; align-items: center; justify-content: center; position: relative;">
                <a href="index.html" style="position: absolute; left: 0; font-size: 1.5rem; text-decoration: none;">🏠</a>
                <h1>Animal Friends</h1>
            </div>
            <h2>Grade 3 Semester 2 - Unit 1</h2>
        </header>
        <div class="challenge-grid" id="challenge-list"></div>
        <div class="footer-links">
            <button class="text-link danger" onclick="app.showMistakes()">⚠ Review My Mistakes</button>
            <button class="text-link muted" onclick="app.showScoreHistory()">View score history</button>
        </div>
    </div>

    <div id="game-screen" class="screen">
        <div class="top-bar">
            <button class="close-btn" onclick="app.goHome()">✕</button>
            <div class="progress-container" id="progress-bar"></div>
        </div>
        <div class="question-area">
            <div class="prompt-container">
                <div class="prompt-cn" id="prompt-cn"></div>
                <button class="prompt-hint-btn" onclick="app.showHint()">💡</button>
                <div class="hint-text" id="hint-text"></div>
            </div>
            <div class="answer-area" id="answer-area"></div>
            <div class="word-pool" id="word-pool"></div>
        </div>
        <div id="feedback-area" class="feedback-area">
            <h3 id="feedback-title" style="margin:0"></h3>
            <p id="feedback-msg" style="margin:5px 0 0"></p>
        </div>
        <div class="footer-action">
            <button id="check-btn" class="check-btn" onclick="app.checkAnswer()">Check</button>
            <button id="next-btn" class="check-btn" onclick="app.nextQuestion()" style="display:none; background-color: var(--secondary); border-bottom-color: var(--secondary-dark);">Continue</button>
        </div>
    </div>

    <div id="mistakes-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2 style="color:var(--danger)">Review Mistakes</h2>
                <button onclick="app.closeMistakes()" class="close-btn" style="color:#333">✕</button>
            </div>
            <div class="log-list" id="mistakes-list"></div>
            <div style="text-align: right;">
                <button class="text-link danger" onclick="app.clearMistakes()">Clear Mistakes</button>
            </div>
        </div>
    </div>

    <div id="history-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Score History</h2>
                <button onclick="app.closeScoreHistory()" class="close-btn" style="color:#333">✕</button>
            </div>
            <div class="log-list" id="history-list"></div>
            <div style="text-align: right; margin-top:10px; border-top:1px solid #eee; padding-top:10px;">
                <button class="text-link danger" onclick="app.clearHistory()">Teacher: Clear All Data</button>
            </div>
        </div>
    </div>
</div>

<script>
    const ID_A = "Zv1SawK574O88W2cq";
    const ipaDict = {"animal":"ˈænɪml","panda":"ˈpændə","elephant":"ˈelɪfənt","bear":"beə","giraffe":"dʒəˈrɑːf","monkey":"ˈmʌŋki","tiger":"ˈtaɪɡə","zebra":"ˈzebrə","strong":"strɒŋ","short":"ʃɔːt","night":"naɪt","picture":"ˈpɪktʃə"};
    const encryptedChallenges = "";
    const builtInKey = 929709432;
    let challenges = [];

    function _0x4f2a(cipherText, key) {
        const _0xb1 = new Uint8Array(4);
        _0xb1[0] = key & 0xFF; _0xb1[1] = (key >> 8) & 0xFF;
        _0xb1[2] = (key >> 16) & 0xFF; _0xb1[3] = (key >> 24) & 0xFF;
        const _0xc2 = atob(cipherText);
        const bytes = new Uint8Array(_0xc2.length);
        for (let i = 0; i < _0xc2.length; i++) {
            bytes[i] = _0xc2.charCodeAt(i) ^ _0xb1[i % 4];
        }
        return new TextDecoder().decode(bytes);
    }

    const app = {
        state: {
            currentChallenge: null, queue: [], mistakeQueue: [],
            currentIndex: 0, userSelection: [], currentObj: null,
            hintUsed: false, scoreLog: [], locked: false
        },
        init: function() { 
            try {
                challenges = JSON.parse(_0x4f2a(encryptedChallenges, builtInKey));
                this.renderHome();
            } catch(e) { console.error("Initialization failed"); }
        },
        getStats: function() { return JSON.parse(localStorage.getItem(ID_A + "-stats_g3s2_u1") || "{}"); },
        saveStats: function(stats) { localStorage.setItem(ID_A + "-stats_g3s2_u1", JSON.stringify(stats)); },
        getMistakes: function() { return JSON.parse(localStorage.getItem(ID_A + "-mistakes_g3s2_u1") || "[]"); },
        saveMistakes: function(list) { localStorage.setItem(ID_A + "-mistakes_g3s2_u1", JSON.stringify(list)); },
        getSessionLogs: function() { return JSON.parse(localStorage.getItem(ID_A + "-session_logs_g3s2_u1") || "[]"); },
        saveSessionLog: function(log) { 
            const logs = this.getSessionLogs(); logs.unshift(log); 
            localStorage.setItem(ID_A + "-session_logs_g3s2_u1", JSON.stringify(logs));
        },
        renderHome: function() {
            document.getElementById("home-screen").classList.add("active");
            document.getElementById("game-screen").classList.remove("active");
            const list = document.getElementById("challenge-list");
            list.innerHTML = "";
            const allStats = this.getStats();
            const todayStr = new Date().toLocaleDateString();
            challenges.forEach(c => {
                let s = allStats[c.id] || { today: {date: todayStr, attempts: 0, best: 0}, lifetime: {attempts: 0, best: 0} };
                if(s.today.date !== todayStr) s.today = { date: todayStr, attempts: 0, best: 0 };
                allStats[c.id] = s;
                const div = document.createElement("div");
                div.className = "challenge-card";
                div.onclick = () => this.startChallenge(c.id);
                div.innerHTML = `<div class="card-header"><div style="display:flex; align-items:center;"><span style="font-size:1.5rem; margin-right:10px;">${c.icon}</span><h3 class="card-title">${c.title}</h3></div><span style="color:var(--primary); font-weight:bold;">START</span></div><div class="card-stats"><div class="stat-row"><span class="stat-label">TODAY</span> <span class="stat-val">${s.today.attempts} Runs | Best: ${s.today.best}%</span></div><div class="stat-row"><span class="stat-label">LIFETIME</span> <span class="stat-val">${s.lifetime.attempts} Runs | Best: ${s.lifetime.best}%</span></div></div>`;
                list.appendChild(div);
            });
            this.saveStats(allStats);
        },
        startChallenge: function(id) {
            const c = challenges.find(x => x.id === id);
            this.state.currentChallenge = c; this.state.queue = [...c.data]; this.state.mistakeQueue = [];
            this.state.currentIndex = 0; this.state.scoreLog = new Array(c.data.length).fill(null);
            document.getElementById("home-screen").classList.remove("active");
            document.getElementById("game-screen").classList.add("active");
            this.renderProgress(); this.loadQuestion();
        },
        loadQuestion: function() {
            let q = null;
            if (this.state.currentIndex < this.state.queue.length) { q = this.state.queue[this.state.currentIndex]; this.state.isRedemption = false; }
            else if (this.state.mistakeQueue.length > 0) { q = this.state.mistakeQueue[0]; this.state.isRedemption = true; }
            else { this.finishGame(); return; }
            this.state.currentObj = q; this.state.userSelection = []; this.state.hintUsed = false; this.state.locked = false;
            document.getElementById("prompt-cn").innerText = q.cn;
            document.getElementById("hint-text").innerText = q.hint;
            document.getElementById("hint-text").classList.remove("visible");
            document.getElementById("feedback-area").className = "feedback-area"; 
            document.getElementById("check-btn").style.display = "block";
            document.getElementById("check-btn").disabled = true;
            document.getElementById("check-btn").className = "check-btn";
            document.getElementById("next-btn").style.display = "none";
            this.renderAnswerArea(); this.generatePool(q);
        },
        generatePool: function(q) {
            const cleanEn = q.en.replace(/[.!?]$/, "");
            const originalWords = cleanEn.split(" ");
            let allWords = [...originalWords, ...q.noise];
            allWords.sort(() => Math.random() - 0.5);
            
            const pool = document.getElementById("word-pool");
            pool.innerHTML = "";
            
            allWords.forEach((word, idx) => {
                const btn = document.createElement("button");
                btn.className = "word-btn";
                
                let displayWord = word;
                const isAcronym = word.length > 1 && word === word.toUpperCase();
                const isI = word === "I";
                const isOriginalCapitalized = word.charAt(0) === word.charAt(0).toUpperCase() && word.charAt(0) !== word.charAt(0).toLowerCase();
                
                // Heuristic: Lowercase everything except:
                // 1. Acronyms (ID, USA, UN)
                // 2. The pronoun "I"
                // 3. Proper nouns/names (detected if they were capitalized in the middle of the original sentence)
                
                let shouldKeepCapital = isAcronym || isI;
                
                if (!shouldKeepCapital && isOriginalCapitalized) {
                    // Check if it's a proper noun by seeing if it's capitalized in the original sentence AND not at the start (or after punctuation)
                    const foundInMiddle = originalWords.some((w, i) => i > 0 && w === word && !originalWords[i-1].match(/[.!?]$/));
                    if (foundInMiddle) {
                        shouldKeepCapital = true;
                    }
                }

                if (!shouldKeepCapital) {
                    displayWord = word.toLowerCase();
                }

                const cleanWord = displayWord.toLowerCase().replace(/[^a-z]/g, "");
                const ipa = ipaDict[cleanWord];
                btn.innerHTML = `<span>${displayWord}</span>${ipa ? `<span class="ipa">[${ipa}]</span>` : ""}`;
                btn.onclick = () => this.selectWord(displayWord, idx, btn); 
                btn.dataset.val = displayWord;
                pool.appendChild(btn);
            });
        },
        selectWord: function(word, id, btn) {
            if (this.state.locked || btn.classList.contains("selected")) return;
            this.state.userSelection.push({ text: btn.dataset.val, srcBtn: btn });
            btn.classList.add("selected");
            this.renderAnswerArea(); this.updateCheckBtn();
        },
        removeWord: function(idx) {
            if (this.state.locked) return;
            const item = this.state.userSelection.splice(idx, 1)[0];
            item.srcBtn.classList.remove("selected");
            this.renderAnswerArea(); this.updateCheckBtn();
        },
        renderAnswerArea: function() {
            const area = document.getElementById("answer-area");
            area.innerHTML = "";
            this.state.userSelection.forEach((item, idx) => {
                const btn = document.createElement("button");
                btn.className = "word-btn-answer";
                let txt = item.text;
                if (idx === 0) {
                    // Only capitalize if it is not already capitalized (like "ID")
                    if (txt.charAt(0) === txt.charAt(0).toLowerCase()) {
                        txt = txt.charAt(0).toUpperCase() + txt.slice(1);
                    }
                }
                btn.innerText = txt;
                btn.onclick = () => this.removeWord(idx);
                area.appendChild(btn);
            });
        },
        showHint: function() { this.state.hintUsed = true; document.getElementById("hint-text").classList.add("visible"); },
        updateCheckBtn: function() { document.getElementById("check-btn").disabled = this.state.userSelection.length === 0; },
        checkAnswer: function() {
            if (this.state.locked || this.state.userSelection.length === 0) return;
            let userSent = this.state.userSelection.map((item, idx) => {
                let t = item.text;
                if (idx === 0) t = t.charAt(0).toUpperCase() + t.slice(1);
                return t;
            }).join(" ");
            this.state.locked = true;
            const target = this.state.currentObj.en.replace(/[.!?]$/, "");
            let isCorrect = userSent.toLowerCase() === target.toLowerCase(); 
            if (!isCorrect && this.state.currentObj.accept) {
                isCorrect = this.state.currentObj.accept.some(alt => alt.replace(/[.!?]$/, "").toLowerCase() === userSent.toLowerCase());
            }
            const feedback = document.getElementById("feedback-area");
            const title = document.getElementById("feedback-title");
            const msg = document.getElementById("feedback-msg");
            const btn = document.getElementById("check-btn");
            if (isCorrect) {
                let scoreType = "green";
                if (this.state.isRedemption) scoreType = "redemption";
                else {
                    if (this.state.hintUsed) scoreType = "yellow";
                    this.state.scoreLog[this.state.currentIndex] = scoreType;
                }
                feedback.className = "feedback-area correct visible";
                title.innerText = "Perfect Structure!"; title.style.color = "#58cc02"; msg.innerText = "";
                btn.className = "check-btn correct";
                if(this.state.isRedemption) this.state.mistakeQueue.shift();
            } else {
                feedback.className = "feedback-area wrong visible";
                title.innerText = "Correct Answer:"; title.style.color = "#ea2b2b"; msg.innerText = this.state.currentObj.en;
                btn.className = "check-btn wrong";
                if (!this.state.isRedemption) {
                    this.state.scoreLog[this.state.currentIndex] = "red";
                    this.state.mistakeQueue.push(this.state.currentObj);
                    this.logMistake(this.state.currentObj, userSent);
                } else this.state.mistakeQueue.push(this.state.mistakeQueue.shift());
            }
            this.renderProgress();
            btn.style.display = "none";
            const nextBtn = document.getElementById("next-btn");
            nextBtn.style.display = "block";
            let isLast = this.state.isRedemption ? (this.state.mistakeQueue.length === 0) : (this.state.currentIndex >= this.state.queue.length - 1 && this.state.mistakeQueue.length === 0);
            if(isLast) { nextBtn.innerText = "Finish"; nextBtn.style.backgroundColor = "var(--primary)"; nextBtn.style.borderBottomColor = "var(--primary-dark)"; }
            else { nextBtn.innerText = "Continue"; nextBtn.style.backgroundColor = "var(--secondary)"; nextBtn.style.borderBottomColor = "var(--secondary-dark)"; }
        },
        nextQuestion: function() { if (!this.state.isRedemption) this.state.currentIndex++; this.loadQuestion(); },
        renderProgress: function() {
            const bar = document.getElementById("progress-bar");
            bar.innerHTML = "";
            for(let i=0; i<10; i++) {
                const seg = document.createElement("div");
                seg.className = "progress-segment";
                const s = this.state.scoreLog[i];
                if(s) seg.classList.add(s);
                bar.appendChild(seg);
            }
        },
        finishGame: function() {
            const total = this.state.scoreLog.reduce((acc, curr) => {
                if (curr === "green") return acc + 10;
                if (curr === "yellow") return acc + 5;
                return acc;
            }, 0);
            const wrongQuestions = [];
            this.state.scoreLog.forEach((status, index) => { if (status === "red" && this.state.queue[index]) wrongQuestions.push(this.state.queue[index]); });
            const allStats = this.getStats();
            const cid = this.state.currentChallenge.id;
            if (!allStats[cid]) allStats[cid] = { today: {date: new Date().toLocaleDateString(), attempts: 0, best: 0}, lifetime: {attempts: 0, best: 0} };
            const s = allStats[cid];
            s.today.attempts++; if (total > s.today.best) s.today.best = total;
            s.lifetime.attempts++; if (total > s.lifetime.best) s.lifetime.best = total;
            this.saveStats(allStats);
            this.saveSessionLog({ date: new Date().toLocaleString(), challenge: this.state.currentChallenge.title, score: total });
            let mistakeHtml = wrongQuestions.length > 0 ? `<div style="width:100%; text-align:left; background:#fff; border-radius:12px; padding:15px; margin:20px 0; max-height:300px; overflow-y:auto; border:2px solid var(--neutral);"><h3 style="color:var(--danger); margin-top:0; border-bottom:1px solid #eee; padding-bottom:5px;">Review Mistakes:</h3>${wrongQuestions.map(q => `<div style="margin-bottom:10px; border-bottom:1px solid #f0f0f0; padding-bottom:5px;"><div style="font-weight:bold; color:#555;">${q.cn}</div><div style="color:var(--primary-dark); font-weight:bold;">${q.en}</div></div>`).join("")}</div>` : `<div style="margin:20px 0; color:var(--primary); font-weight:bold; font-size:1.2rem;">🎉 Perfect Run! No mistakes.</div>`;
            document.getElementById("game-screen").innerHTML = `<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; text-align:center; padding:20px;"><h1 style="color:var(--primary); font-size:3rem; margin:0;">${total}%</h1><h2 style="margin:5px 0 20px 0; color:#555;">Challenge Complete!</h2>${mistakeHtml}<button onclick="location.reload()" class="check-btn" style="width:100%; max-width:300px;">Back to Challenges</button></div>`;
        },
        logMistake: function(qObj, userAns) {
            const list = this.getMistakes();
            const existing = list.find(m => m.en === qObj.en);
            if(existing) { existing.count++; existing.wrong = userAns; existing.timestamp = Date.now(); list.splice(list.indexOf(existing), 1); list.unshift(existing); }
            else list.unshift({ en: qObj.en, cn: qObj.cn, wrong: userAns, count: 1, timestamp: Date.now(), challenge: this.state.currentChallenge.title });
            this.saveMistakes(list);
        },
        showMistakes: function() {
            const list = this.getMistakes(); const container = document.getElementById("mistakes-list"); container.innerHTML = "";
            if(list.length === 0) container.innerHTML = "<div style='text-align:center; padding:20px; color:#999;'>No mistakes yet! Great job!</div>";
            else list.forEach(m => {
                const div = document.createElement("div"); div.className = "mistake-item";
                div.innerHTML = `<div style="font-size:0.8rem; color:#999; margin-bottom:5px;">${new Date(m.timestamp).toLocaleDateString()} - ${m.challenge}<span class="fail-count">Failed ${m.count}x</span></div><div style="font-weight:bold; color:#333; margin-bottom:3px;">${m.cn}</div><div style="color:var(--danger); text-decoration:line-through; font-size:0.9rem;">${m.wrong || "(No answer)"}</div><div style="color:var(--primary-dark); font-weight:bold; font-size:0.9rem;">${m.en}</div>`;
                container.appendChild(div);
            });
            document.getElementById("mistakes-modal").style.display = "flex";
        },
        closeMistakes: function() { document.getElementById("mistakes-modal").style.display = "none"; },
        clearMistakes: function() {
            const code = prompt("Enter Teacher Passcode:");
            if(code && code.toUpperCase() === "NDAYD") { localStorage.removeItem(ID_A + "-mistakes_g3s2_u1"); this.showMistakes(); }
            else alert("Incorrect Passcode");
        },
        showScoreHistory: function() {
            const list = this.getSessionLogs(); const container = document.getElementById("history-list"); container.innerHTML = "";
            if(list.length === 0) container.innerHTML = "<div style='text-align:center; padding:20px; color:#999;'>No games played yet.</div>";
            else list.forEach(l => {
                const div = document.createElement("div"); div.className = "mistake-item";
                div.innerHTML = `<div style="display:flex; justify-content:space-between; align-items:center;"><strong style="color:#333;">${l.challenge}</strong><span style="font-weight:bold; color:var(--primary);">${l.score}%</span></div><div style="font-size:0.8rem; color:#999;">${l.date}</div>`;
                container.appendChild(div);
            });
            document.getElementById("history-modal").style.display = "flex";
        },
        closeScoreHistory: function() { document.getElementById("history-modal").style.display = "none"; },
        clearHistory: function() {
            const code = prompt("Enter Teacher Passcode:");
            if(code && code.toUpperCase() === "NDAYD") {
                localStorage.removeItem(ID_A + "-stats_g3s2_u1");
                localStorage.removeItem(ID_A + "-session_logs_g3s2_u1");
                location.reload();
            } else alert("Incorrect Passcode");
        },
        goHome: function() { if(confirm("Exit? Progress will be lost.")) location.reload(); }
    };

    window.onload = function() { app.init(); };
</script>
</body>
</html>
