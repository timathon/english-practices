            "state": "hidden",
            "children": [
              {
                "id": "s_poems_sub",
                "text": "胡儿以“撒盐空中”相比（重形），兄女以“柳絮因风起”相比（重神）。",
                "emoji": "🧂",
                "state": "hidden",
                "children": []
              }
            ]
          },
          {
