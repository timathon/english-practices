            "children": [
              {
                "id": "s_intro_sub",
                "text": "陈太丘与友期行，期日中。过中不至，太丘舍去，去后乃至。",
                "emoji": "⏳",
                "state": "hidden",
                "children": []
              }
            ]
          },
          {
            "id": "s_scene",
            "text": "承：门外对话",
            "emoji": "💬",
            "state": "hidden",
            "children": [
              {
                "id": "s_scene_sub",
                "text": "元方时年七岁，门外戏。客问元方：“尊君在不？”答曰：“待君久不至，已去。”",
                "emoji": "👦",
                "state": "hidden",
                "children": []
              }
            ]
          },
          {
            "id": "s_conflict",
            "text": "转：据理力争",
            "emoji": "⚖️",
            "state": "hidden",
            "children": [
              {
                "id": "s_conflict_sub",
                "text": "友人怒斥太丘相委而去。元方以“无信”（日中不至）与“无礼”（对子骂父）反驳之。",
                "emoji": "⚡",
                "state": "hidden",
                "children": []
              }
            ]
          },
          {
            "id": "s_ending",
            "text": "合：友惭不顾",
            "emoji": "🚪",
            "state": "hidden",
            "children": [
              {
                "id": "s_ending_sub",
                "text": "友人惭愧，下车引之。元方入门不顾，表现其方正刚直的性格。",
                "emoji": "🚶‍♂️",
                "state": "hidden",
                "children": []
              }
            ]
          }
        ]
      },
