  "challenges": [
    {
      "id": "c1",
      "title": "What & How Exclamations",
      "icon": "🧙‍♂️",
      "questions": [
        {
          "id": "g8u5g101",
          "type": "multiple-choice",
          "category": "purpose",
          "prompt": "感叹句的主要交际功能是什么？",
          "options": [
            "表达强烈的感情",
            "询问未知的信息",
            "陈述客观的事实",
            "给出礼貌的建议"
          ],
          "answer": 0,
          "explanation": "感叹句主要用于表达强烈的感情，如惊讶、赞美、愤怒或喜悦等。",
          "hint": "想想句末叹号的作用。"
        },
        {
          "id": "g8u5g102",
          "type": "multiple-choice",
          "category": "definition",
          "prompt": "在感叹句 'What an amazing smell it is!' 中，核心修饰的词是什么词性？",
          "options": [
            "名词",
            "形容词",
            "副词",
            "动词"
          ],
          "answer": 0,
          "explanation": "What引导的感叹句，核心修饰的是名词（名词短语）。本句的核心是名词smell（气味）。",
          "hint": "What修饰名词，How修饰形容词或副词。"
        },
        {
          "id": "g8u5g103",
          "type": "multiple-choice",
          "category": "formation",
          "prompt": "选出填空最恰当的一项：________ delicious the mashed potatoes taste!",
          "options": [
            "How",
            "What",
            "What a",
            "How a"
          ],
          "answer": 0,
          "explanation": "因为delicious是形容词，修饰形容词要用How引导感叹句。结构为：How + 形容词/副词 + 主语 + 谓语！",
          "hint": "delicious是形容词。"
        },
        {
          "id": "g8u5g104",
          "type": "multiple-choice",
          "category": "usage",
          "prompt": "完成句子：________ mess you have made in the kitchen!",
          "options": [
            "What a",
            "How",
            "What",
            "How a"
          ],
          "answer": 0,
          "explanation": "mess是单数可数名词，表示“脏乱，凌乱”。感叹单数可数名词用 What + a/an + 形容词 + 单数可数名词！",
          "hint": "mess是单数名词。"
        },
        {
          "id": "g8u5g105",
          "type": "multiple-choice",
          "category": "differentiation",
          "prompt": "选出下列感叹句中错误的一项：",
          "options": [
            "How wonderful life is!",
            "What a lovely cake!",
            "What lucky we are!",
            "How time flies!"
          ],
          "answer": 2,
          "explanation": "lucky是形容词，应该用How引导：How lucky we are! 而不能用What修饰形容词。",
          "hint": "检查What和How后面的词性。"
        },
        {
          "id": "g8u5g106",
          "type": "multiple-choice",
          "category": "formation",
          "prompt": "选出填空最恰当的一项：________ pumpkin pie she always makes in autumn!",
          "options": [
            "What a delicious",
            "How delicious",
            "What delicious",
            "How a delicious"
          ],
          "answer": 0,
          "explanation": "pumpkin pie是可数名词单数，因此需要用What a + 形容词 + 名词单数。",
          "hint": "pie是可数名词单数。"
        },
        {
          "id": "g8u5g107",
          "type": "multiple-choice",
          "category": "usage",
          "prompt": "选出填空最恰当的一项：________ nice weather it is today!",
          "options": [
            "What",
            "What a",
            "How",
            "How a"
          ],
          "answer": 0,
          "explanation": "weather是不可数名词，不能用冠词a/an。感叹不可数名词句型为：What + 形容词 + 不可数名词！",
          "hint": "weather是不可数名词吗？"
        },
        {
          "id": "g8u5g108",
          "type": "multiple-choice",
          "category": "differentiation",
          "prompt": "选出填空最恰当的一项：________ clever kids they are!",
          "options": [
            "What",
            "What a",
            "How",
            "How a"
          ],
          "answer": 0,
          "explanation": "kids是名词复数，感叹名词复数句型为：What + 形容词 + 名词复数！不能加a/an。",
          "hint": "注意kids是复数。"
        },
        {
          "id": "g8u5g109",
          "type": "multiple-choice",
          "category": "formation",
          "prompt": "选出填空最恰当的一项：________ fast the athlete runs!",
          "options": [
            "How",
            "What",
            "What a",
            "How a"
          ],
          "answer": 0,
          "explanation": "fast在此处是副词，修饰副词用How。结构为：How + 形容词/副词 + 主语 + 谓语！",
          "hint": "fast修饰动词runs，是副词。"
        },
        {
          "id": "g8u5g110",
          "type": "multiple-choice",
          "category": "usage",
          "prompt": "完成句子：________ beautiful day it is to go boating!",
          "options": [
            "What a",
            "How",
            "What",
            "How a"
          ],
          "answer": 0,
          "explanation": "day是单数可数名词，感叹单数可数名词用What a + 形容词 + 名词。",
          "hint": "day是单数可数名词。"
        }
      ]
    },
