        "emoji": "📅",
        "keywords": "September",
        "children": [
          {
            "id": "p3_1",
            "text": "A great fire started in London this morning!",
            "emoji": "🔥",
            "keywords": "great fire, London",
            "children": [
              {
                "id": "p3_1_1",
                "text": "The fire is now growing very quickly.",
